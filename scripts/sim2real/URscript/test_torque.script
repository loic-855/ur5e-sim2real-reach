# Test script for direct_torque() availability
# Applies very small torques for 3 seconds

def test_torque():
    textmsg("Starting torque test...")
    
    # Very small test torques (safe)
    tau_test = [0.5, 0.5, 0.5, 0.2, 0.2, 0.2]
    
    duration = 3.0
    timer = 0.0
    
    while timer < duration:
        timer = timer + get_steptime()
        
        # Try to apply small torques
        direct_torque(tau_test)
        
        # Log every 0.5s
        if timer > 0.0 and timer < 0.01:
            textmsg("Torque command sent successfully")
        end
    end
    
    # Zero torques at end
    direct_torque([0, 0, 0, 0, 0, 0])
    textmsg("Torque test complete")
end

test_torque()
